# =============================================================================
# ACE TURBO — .gitignore
# Next.js 14 · TypeScript · Prisma · MySQL · Redis · Stripe · eBay
# =============================================================================

# =============================================================================
# SECURITY — NEVER COMMIT THESE
# =============================================================================
.env
.env.*
!.env.example          # Keep the template
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
secrets/
config/secrets.*

# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# =============================================================================
# NEXT.JS
# =============================================================================
.next/
/out/
/build
next-env.d.ts

# =============================================================================
# TYPESCRIPT
# =============================================================================
*.tsbuildinfo
dist/
*.d.ts.map

# =============================================================================
# PRISMA
# =============================================================================
# Keep schema.prisma and seed files — ignore generated client & migration locks
prisma/generated/
!prisma/migrations/          # Track migrations in version control
prisma/migrations/migration_lock.toml

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
/coverage
/.nyc_output
/test-results/
/playwright-report/
/playwright/.cache/
*.snap

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# =============================================================================
# CACHE & BUILD ARTIFACTS
# =============================================================================
.cache/
.parcel-cache/
.turbo/
.swc/
.eslintcache
.stylelintcache
*.tgz
*.tar.gz

# =============================================================================
# UPLOADS & USER DATA
# =============================================================================
public/uploads/
public/invoices/
storage/
tmp/
temp/
.data/

# =============================================================================
# DATABASE
# =============================================================================
*.sql.bak
*.db
*.sqlite
*.sqlite3
mysql-data/
redis-data/
dump.rdb              # Redis dump file

# =============================================================================
# STRIPE
# =============================================================================
.stripe/

# =============================================================================
# EBAY / API TOKENS
# =============================================================================
ebay-tokens/
dvla-cache/

# =============================================================================
# VERCEL / DEPLOYMENT
# =============================================================================
.vercel
.netlify

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# =============================================================================
# IDEs & EDITORS
# =============================================================================
.vscode/*
!.vscode/extensions.json    # Share recommended extensions
!.vscode/settings.json      # Share workspace settings
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# =============================================================================
# MISC
# =============================================================================
*.pem
.node_repl_history
*.pid
*.seed
*.pid.lock
jspm_packages/
web_modules/


# =============================================================================
# NODE_MODULES (EXCLUDE FROM GIT)
# =============================================================================
node_modules/
node_modules/
.next/
out/
build/
.env*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
